<UserControl x:Class="DMCApp.View.UserControls.MyMenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DMCApp.View.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Menu FontSize="16">
            <MenuItem Header="File" >
                <MenuItem Header="New Table"/>
                <MenuItem Header="Open DB" />
                <MenuItem Header="..." />
                <MenuItem Header="..." />
                <MenuItem Header="Exit" />
            </MenuItem>

            <MenuItem Header="Edit">
                <MenuItem Header="Undo">
                    <MenuItem.Icon>
                        <Image Source="/Content/img/undo.ico" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Redo" FontSize="16" IsEnabled="False">
                    <MenuItem.Icon>
                        <Image Source="/Content/img/redo.ico" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Cut" FontSize="16">
                    <MenuItem.Icon>
                        <Image Source="/Content/img/cut.ico" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Copy" FontSize="14">
                    <MenuItem.Icon>
                        <Image Source="/Content/img/copy.ico" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Paste" FontSize="14">

                    <MenuItem.Icon>
                        <Image Source="/Content/img/paste.ico" Width="16" Height="16" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="View">
                <MenuItem Header="Change side" />
                <MenuItem Header="Change side 2" />
            </MenuItem>

            <MenuItem Header="Setting">
                <MenuItem Header="Add DataMart DB" />
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="About Us" />
            </MenuItem>
        </Menu>
    </Grid>
</UserControl>
