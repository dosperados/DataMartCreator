<ui:FluentWindow x:Class="DMCApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:DMCApp.Views"
        xmlns:vm="clr-namespace:DMCApp.ViewModels"
        mc:Ignorable="d"
        Title="DMCApp" Height="800" Width="1200"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="3" Title="DMCApp" />

        <!-- Sidebar -->
        <ui:TabView Grid.Row="1" Grid.Column="0">
            <ui:TabViewItem Header="TableDefine">
                <views:TableDefineView DataContext="{Binding TableDefineVM}"/>
            </ui:TabViewItem>
            <ui:TabViewItem Header="ViewDefine">
                <TextBlock Text="Stub: ViewDefine" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ui:TabViewItem>
            <ui:TabViewItem Header="IndexDefine">
                <TextBlock Text="Stub: IndexDefine" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </ui:TabViewItem>
        </ui:TabView>

        <!-- Splitter -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource TextFillColorSecondaryBrush}"/>

        <!-- Workspace -->
        <ui:TabView Grid.Row="1" Grid.Column="2" x:Name="MainTabs">
            <ui:TabViewItem Header="Workspace">
                <TextBlock Text="Select an item from the sidebar or click Add New" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </ui:TabViewItem>
        </ui:TabView>
    </Grid>
</ui:FluentWindow>
