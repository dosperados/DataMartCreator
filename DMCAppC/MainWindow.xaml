<Window x:Class="DMCApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:userControls="clr-namespace:DMCApp.View.UserControls"
        xmlns:local="clr-namespace:DMCApp"
        mc:Ignorable="d"
        Title="DataMart Creator APP" Height="450" Width="800"
        x:Name="Root">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>

        </Grid.RowDefinitions>

        <!--MenuBar  $(MSBuildProjectName.Replace(" ", "_")) -->
        <userControls:MyMenuBar Grid.Row="0" />

        <!-- Основное содержимое -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*">

                </ColumnDefinition>
            </Grid.ColumnDefinitions>
            <!-- DB List -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Dbs}" AutoGenerateColumns="True" 
                  Margin="5" IsReadOnly="False" CanUserAddRows="True"/>

            <Grid Background="#FFF0F0F0" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!--Button Grid.Row="0" Content="Add table"  HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="5,0,5,0" Command="{Binding AddNewTableCommand}"/-->
                <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center" Margin="5,0,5,0">
                    <Button Content="Add Table" Command="{Binding AddNewTableCommand}" Margin="0,0,5,0"/>
                    <Button Name="ToggleShowAllButton" Command="{Binding ToggleShowAllCommand}" Margin="0,0,5,0">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Show All Deleted"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShowingAll}" Value="True">
                                            <Setter Property="Text" Value="Hide Deleted"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                </StackPanel>

                <TabControl Margin="5" Grid.Row="1">
                    <!--Table-->
                    <TabItem Header="Tables">
                        <DataGrid ItemsSource="{Binding Tables}" AutoGenerateColumns="False" CanUserAddRows="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TableName" Binding="{Binding TableName}" />
                                <DataGridTextColumn Header="SchemaName" Binding="{Binding SchemaName}" />
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" />

                                <!-- Используем TemplateColumn для отображения и редактирования -->
                                <DataGridTemplateColumn Header="Db">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Db.DBName}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.Dbs, ElementName=Root}"
                                                      SelectedValue="{Binding DBId, Mode=TwoWay}"
                                                      SelectedValuePath="DBId"
                                                      DisplayMemberPath="DBName"
                                                      Width="200" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <!--Column-->
                    <TabItem Header="Columns">
                        <!-- Column List -->
                        <DataGrid ItemsSource="{Binding Columns}"  AutoGenerateColumns="False"
                                   Margin="5" IsReadOnly="False" CanUserAddRows="True">
                            <DataGrid.Columns>
                                <!--DataGridTextColumn Header="TableName" Binding="{Binding TableName}" /-->
                                <DataGridComboBoxColumn Header="TableName"
                                                        SelectedValueBinding="{Binding TableId, Mode=TwoWay}"
                                                        DisplayMemberPath="TableName"
                                                        SelectedValuePath="TableId"
                                                        ItemsSource="{Binding DataContext.Tables, ElementName=Root}" />
                                <DataGridTextColumn Header="ColumnName" Binding="{Binding ColumnName}" />
                                <DataGridTextColumn Header="ColumnSortNo" Binding="{Binding ColumnSortNo}" />
                                <DataGridTextColumn Header="DataType" Binding="{Binding DataType}" />
                                <DataGridTextColumn Header="MaxLength" Binding="{Binding MaxLength}" />
                                <DataGridTextColumn Header="Precision" Binding="{Binding Precision}" />
                                <DataGridTextColumn Header="Scale" Binding="{Binding Scale}" />
                                <DataGridTextColumn Header="CollationName" Binding="{Binding CollationName}" />
                                <DataGridTextColumn Header="DefaultValue" Binding="{Binding DefaultValue}" />
                                <DataGridTextColumn Header="KeySortNo" Binding="{Binding KeySortNo}" />
                                <DataGridCheckBoxColumn Header="IsNullable" Binding="{Binding IsNullable}" />
                                <DataGridCheckBoxColumn Header="IsOptionField" Binding="{Binding IsOptionField}" />
                                <DataGridTextColumn Header="FieldType" Binding="{Binding FieldType}" />
                                <DataGridCheckBoxColumn Header="IsLookupField" Binding="{Binding IsLookupField}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <!--Db-->
                    <TabItem Header="Table2">

                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="2"  Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right"  Margin="5,0,5,0">
                    <Button Content="Delete" Command="{Binding SoftDeleteCommand}" Margin="0,0,5,0"/>
                    <Button  Content="Save changes"  HorizontalAlignment="Right" VerticalAlignment="Center"
                             Margin="0,0,5,0" Command="{Binding SaveChangesCommand}"/>
                </StackPanel>
                <!-- Save Button -->


            </Grid>
        </Grid>

        <ToolBarTray Grid.Row="2"/>
        <ToolBar Grid.Row="2" />
    </Grid>
</Window>
