<ui:FluentWindow x:Class="DMCApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:DMCApp.Views"
        xmlns:vm="clr-namespace:DMCApp.ViewModels"
        mc:Ignorable="d"
        Title="DMCApp" Height="800" Width="1200"
        ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:TableEditorViewModel}">
            <views:TableEditorView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <TabControl Grid.Column="0">
            <TabItem Header="TableDefine">
                <views:TableDefineView DataContext="{Binding TableDefineVM}"/>
            </TabItem>
            <TabItem Header="ViewDefine">
                <TextBlock Text="Stub: ViewDefine" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </TabItem>
            <TabItem Header="IndexDefine">
                <TextBlock Text="Stub: IndexDefine" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </TabItem>
        </TabControl>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Gray"/>

        <!-- Workspace -->
        <ui:TabView Grid.Column="2" x:Name="MainTabs" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}">
             <ui:TabView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" />
                </DataTemplate>
            </ui:TabView.ItemTemplate>
             <!-- Content Template stub -->
        </ui:TabView>
    </Grid>
</ui:FluentWindow>
